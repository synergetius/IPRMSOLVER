	$(MAKE) $(MAKESILENT) -f CMakeFiles\qoco.dir\build.make CMakeFiles/qoco.dir/src/utils.c.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles\qocostatic.dir\build.make CMakeFiles/qocostatic.dir/src/utils.c.s
.PHONY : src/utils.c.s

